#!/usr/bin/env bash

set -euo pipefail

CONFIG="config/config.yaml"
CORES=""
PROFILE=""
DRYRUN=()
SNAKEMAKE_ARGS=()
TARGET=""

usage() {
cat << 'EOF'
                    /^\/^\
                   _|__|  O|
          \/     /~     \_/ \
           \____|__________/  \
                  \_______     \
                          `\    \
                            |    |
                           /    /
                          /    /
                        /    /
                      /    /      SnakePop v1     
                     |    |                      ~~
                     |    |                     /*/
                      \    \                   /*/
                       \    \______________---/*/
                        \                   _/*/
                         \_______________--'

                           ~~~ SSSSSSSSS ~~~

Usage:
  ./snakepop <target> --cores N [options]

Core workflow:
  alignment             Map reads to the reference genome
  raw_calling           Generate raw variant calls
  filtering             Apply genotype and site filters
  final_callset         Build final VCF callsets
  variants              Run raw_calling → filtering → final_callset
  all                   Run the complete workflow

Population genomics:
  pca                   Genome-wide PCA
  heterozygosity        Per-sample heterozygosity and inbreeding coefficient
  roh                   Runs of homozygosity
  popgenwindows         Windowed FST, dXY, dA and pi
  manhattan             Manhattan-style genome scan plots and candidate regions
  winpca                Windowed PCA
  popstats              Run all configured population-genomic modules

Phylogenomics:
  snptrees_iqtree       Windowed SNP trees with IQ-TREE
  astral                ASTRAL species tree from SNP window trees
  dsuite                Dsuite introgression tests (to be implemented)
  twisst

Cleanup:
  clean_intermediates   Remove intermediate variant-calling files
  clean_snakemake       Remove Snakemake metadata and locks

Options:
  --cores N              Maximum local cores for Snakemake
  --config FILE          Config file [default: config/config.yaml]
  --profile PROFILE      Snakemake profile
  --dry-run, -n          Dry run with printed commands
  --snakemake "ARGS"     Extra arguments passed directly to Snakemake
  --help, -h             Show this help

Examples:
  ./snakepop alignment --cores 8 --dry-run
  ./snakepop variants --cores 32 --snakemake "--rerun-incomplete --keep-going"
  ./snakepop pca --cores 16
  ./snakepop heterozygosity --cores 4
  ./snakepop roh --cores 4
  ./snakepop popgenwindows --cores 16
  ./snakepop manhattan --cores 4
  ./snakepop winpca --cores 16
  ./snakepop snptrees_iqtree --cores 8
  ./snakepop astral --cores 1
  ./snakepop popstats --cores 32
  ./snakepop alignment --cores 8 --snakemake "--unlock"
EOF
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

case "$1" in
    alignment|raw_calling|filtering|final_callset|variants|all|\
pca|heterozygosity|roh|popgenwindows|manhattan|winpca|popstats|\
snptrees_iqtree|astral|dsuitei|twisst|\
clean_intermediates|clean_snakemake)
        TARGET="$1"
        shift
        ;;
    -h|--help)
        usage
        exit 0
        ;;
    *)
        echo "ERROR: Unknown target '$1'"
        echo
        usage
        exit 1
        ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        --cores)
            CORES="${2:-}"
            shift 2
            ;;

        --config)
            CONFIG="${2:-}"
            shift 2
            ;;

        --profile)
            PROFILE="${2:-}"
            shift 2
            ;;

        -n|--dry-run)
            DRYRUN=(-n -p)
            shift
            ;;

        --snakemake)
            read -r -a EXTRA <<< "${2:-}"
            SNAKEMAKE_ARGS+=("${EXTRA[@]}")
            shift 2
            ;;

        -h|--help)
            usage
            exit 0
            ;;

        *)
            echo "ERROR: Unknown option '$1'"
            echo
            usage
            exit 1
            ;;
    esac
done

if [[ -z "$CORES" ]]; then
    echo "ERROR: --cores is required"
    echo
    usage
    exit 1
fi


CMD=(
    snakemake
    --snakefile workflow/Snakefile
    --configfile "$CONFIG"
    --cores "$CORES"
)

if [[ -n "$PROFILE" ]]; then
    CMD+=(--profile "$PROFILE")
fi

CMD+=("${DRYRUN[@]}")
CMD+=("${SNAKEMAKE_ARGS[@]}")
CMD+=("$TARGET")

echo
echo "Running:"
printf '%q ' "${CMD[@]}"
echo
echo

"${CMD[@]}"
